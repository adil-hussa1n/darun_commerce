# SheetDB API endpoint URLs for Google Sheets database integration.
# Option A: Use separate endpoints for products and sales spreadsheets:
VITE_SHEETDB_PRODUCTS_URL=
VITE_SHEETDB_SALES_URL=

# Option B: Use a single API endpoint (assumes sheets named "products" and "sales" in one file):
VITE_SHEETDB_API_URL=
